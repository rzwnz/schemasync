# ── Telegram Bot ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=REPLACE_WITH_REAL_TOKEN
ADMIN_CHAT_ID=REPLACE_WITH_REAL_ADMIN_CHAT_ID

# ── Microservice ─────────────────────────────────────────
API_KEY=REPLACE_WITH_STRONG_API_KEY
MICROSERVICE_API_KEY=REPLACE_WITH_STRONG_API_KEY

# ── PostgreSQL (overridden in docker-compose environment) ─
METADB_USER=sync_user
METADB_PASS=REPLACE_WITH_STRONG_PASSWORD
VALIDATION_DB_USER=sync_user
VALIDATION_DB_PASS=REPLACE_WITH_STRONG_PASSWORD
TEST_DB_USER=sync_user
TEST_DB_PASS=REPLACE_WITH_STRONG_PASSWORD
PROD_DB_USER=sync_user
PROD_DB_PASS=REPLACE_WITH_STRONG_PASSWORD

# ── Jenkins ──────────────────────────────────────────────
JENKINS_URL=http://schemasync-jenkins:8080
JENKINS_USER=REPLACE_WITH_JENKINS_USER
JENKINS_TOKEN=REPLACE_WITH_JENKINS_API_TOKEN
JENKINS_JOB_NAME=schema-apply
JENKINS_TRIGGER_TOKEN=REPLACE_WITH_TRIGGER_TOKEN

# ── Bot pipelines ───────────────────────────────────────
BOT_PIPELINES=default-pipeline
